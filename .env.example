# Application
APP_NAME=GL Regulatory Reporting System
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gl_reporting
DATABASE_USER=gl_user
DATABASE_PASSWORD=gl_password
DATABASE_URL=postgres://gl_user:gl_password@localhost:5432/gl_reporting

# Redis / Qdrant
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# LLM
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=gl-reporting-dev
AWS_SECRETS_MANAGER_SECRET_ID=gl-reporting/dev
